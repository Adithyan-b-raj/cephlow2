# Hashed assets — cache forever (Vite adds content hash to filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate so users get latest app, and enforce security headers (M-2, M-3, M-4)
/*
  Cache-Control: no-cache
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://*.supabase.co https://api.cephlow.in https://api-test.cephlow.in https://api.cephlow.online https://*.cashfree.com; img-src 'self' data: https://*.r2.cloudflarestorage.com https://*.r2.dev; script-src 'self' 'unsafe-inline' https://sdk.cashfree.com https://*.cashfree.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; frame-src 'self' https://*.cashfree.com; frame-ancestors 'none';


