  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
